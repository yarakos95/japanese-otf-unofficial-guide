\ProvidesPackage{ajmacros-cmd}
\RequirePackage{expl3}
\ExplSyntaxOn

\tl_new:N \l__ajmacroscmd_part_tl
\tl_new:N \l__ajmacroscmd_part_start_tl
\tl_new:N \l__ajmacroscmd_part_end_tl
\clist_new:N \l__ajmacroscmd_clist

\cs_new:Npn \__ajmacroscmd_clist:nn #1#2
{
    \clist_set:Nn \l__ajmacroscmd_clist { #2 }
    % \clist_pop:NN \l__ajmacroscmd_clist \l_tmpa_tl
    % \cs:w #1\cs_end:{ \tl_use:N \l_tmpa_tl }
    \clist_map_inline:Nn \l__ajmacroscmd_clist
    {
        \,
        \tl_set:Nn \l__ajmacroscmd_part_tl { ##1 }
        \tl_if_in:NnTF \l__ajmacroscmd_part_tl { = }
            {
                \seq_set_split:NnV \l_tmpa_seq { = } \l__ajmacroscmd_part_tl
                \seq_pop_left:NN  \l_tmpa_seq \l__ajmacroscmd_part_start_tl
                \seq_pop_right:NN \l_tmpa_seq \l__ajmacroscmd_part_end_tl
                \int_set:Nn \l_tmpa_int { \tl_use:N \l__ajmacroscmd_part_start_tl }
                \int_set:Nn \l_tmpb_int { \tl_use:N \l__ajmacroscmd_part_end_tl }
                \int_step_inline:nnn { \int_use:N \l_tmpa_int } { \int_use:N \l_tmpb_int }
                    {
                        \cs:w #1\cs_end:{ ####1 }
                    }
            }
        \tl_if_in:NnTF \l__ajmacroscmd_part_tl { - }
            {
                \seq_set_split:NnV \l_tmpa_seq { - } \l__ajmacroscmd_part_tl
                \seq_pop_left:NN  \l_tmpa_seq \l__ajmacroscmd_part_start_tl
                \seq_pop_right:NN \l_tmpa_seq \l__ajmacroscmd_part_end_tl
                \cs:w #1\cs_end:{ \tl_use:N \l__ajmacroscmd_part_start_tl }
                \dots
                \cs:w #1\cs_end:{ \tl_use:N \l__ajmacroscmd_part_end_tl }
            }
            {
                \cs:w #1\cs_end:{ ##1 }
            }
    }
}

\cs_new:Npn \__ajmacroscmd_clist_with_star:nn #1#2
{
    \clist_set:Nn \l__ajmacroscmd_clist { #2 }
    \clist_pop:NN \l__ajmacroscmd_clist \l_tmpa_tl
    \cs:w #1\cs_end:*{ \tl_use:N \l_tmpa_tl }
    \clist_map_inline:Nn \l__ajmacroscmd_clist
    {
        \,
        \tl_set:Nn \l__ajmacroscmd_part_tl { ##1 }
        \tl_if_in:NnTF \l__ajmacroscmd_part_tl { - }
            {
                \seq_set_split:NnV \l_tmpa_seq { - } \l__ajmacroscmd_part_tl
                \seq_pop_left:NN  \l_tmpa_seq \l__ajmacroscmd_part_start_tl
                \seq_pop_right:NN \l_tmpa_seq \l__ajmacroscmd_part_end_tl
                \cs:w #1\cs_end:*{ \tl_use:N \l__ajmacroscmd_part_start_tl }
                \dots
                \cs:w #1\cs_end:*{ \tl_use:N \l__ajmacroscmd_part_end_tl }
            }
            {
                \cs:w #1\cs_end:*{ ##1 }
            }
    }
}

\NewDocumentCommand{ \ajCounterSample }{ m s m }
{
    \group_begin:
    \IfBooleanTF{ #2 }
        { \__ajmacroscmd_clist_with_star:nn { #1 } { #3 } }
        { \__ajmacroscmd_clist:nn { #1 } { #3 } }
    \group_end:
}

\ExplSyntaxOff
